{
  "installCommand": "cd farmacia-app && npm install --ignore-scripts",
  "buildCommand": "cd farmacia-app && node node_modules/expo/bin/cli export --platform web",
  "outputDirectory": "farmacia-app/dist",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
